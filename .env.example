APP_ENV=dev
APP_NAME=JD Agentic Test System

# Core API / AI settings
GOOGLE_API_KEY=
GEMINI_TEMPERATURE=0.2
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_PLANNER_MODEL=gemini-2.5-flash-lite
GEMINI_GENERATION_MODEL=gemini-2.5-flash-lite
GEMINI_CRITIC_MODEL=gemini-2.5-flash-lite
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=JD_AI-agentic

# Database
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?sslmode=require

# Frontend access
FRONTEND_ORIGIN=http://localhost:3000
# FRONTEND_ORIGINS=http://localhost:3000,https://your-frontend.onrender.com

# Firebase Admin authentication
# Local development: point to your downloaded serviceAccountKey.json file.
FIREBASE_SERVICE_ACCOUNT_PATH=firebase/serviceAccountKey.json

# Render / env-only deployment options:
# Option 1: paste the full service account JSON as a single env value.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option 2: paste base64-encoded service account JSON.
# FIREBASE_SERVICE_ACCOUNT_B64=eyJ0eXBlIjoi...
